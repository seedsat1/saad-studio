{
  "manifestVersion": 5,
  "id": "com.saadstudio.editpilot",
  "name": "EditPilot AI",
  "version": "1.0.0",
  "author": "Saad Studio",
  "description": "AI-powered video editing assistant for Premiere Pro — by Saad Studio",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "24.0.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "editpilot.panel",
      "label": {
        "default": "EditPilot AI"
      },
      "minimumSize": {
        "width": 380,
        "height": 560
      },
      "maximumSize": {
        "width": 800,
        "height": 1200
      },
      "preferredDockedSize": {
        "width": 400,
        "height": 700
      }
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": [
        "https://saadstudio.app",
        "https://fonts.googleapis.com",
        "https://fonts.gstatic.com"
      ]
    },
    "localFileSystem": "request",
    "clipboard": "readAndWrite",
    "ipc": {
      "enablePluginCommunication": false
    }
  }
}
