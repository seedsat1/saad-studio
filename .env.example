# ─────────────────────────────────────────────
# SAAD STUDIO — Environment Variables
# Copy this file to .env and fill in every value.
# NEVER commit .env to git.
# ─────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────

# KIE.ai API key (get from https://kie.ai/dashboard)
KIE_API_KEY=your_kie_api_key_here

# Admin credentials — use a strong unique password (min 12 chars)
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_strong_password_here

# ── STRONGLY RECOMMENDED ───────────────────────

# Set to 'production' before deploying; enables error scrubbing and strict checks
NODE_ENV=production

# Your public domain (no trailing slash). Required in production to lock CORS.
# Example: https://saadstudio.com
ALLOWED_ORIGIN=https://your-domain.com

# ── OPTIONAL / EXTERNAL SERVICES ──────────────

# Google Gemini API key
GEMINI_API_KEY=

# Google OAuth Client ID (public — safe to set)
GOOGLE_CLIENT_ID=

# Supabase (optional — only used for token verification if set)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Port to listen on (default: 6188)
PORT=6188

# Enable ComfyUI local image generation (default: false)
COMFY_ENABLED=false

# GPT-5 model fallback order (comma-separated)
KIE_GPT_FALLBACKS=gpt-5-2,gpt-5-4,gpt-4.1,gpt-4o-mini
