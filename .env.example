# ─────────────────────────────────────────────────────────────
# ENVIRONMENT VARIABLES — Saad Studio
# Copy to .env (Railway) or paste into Vercel Dashboard
# NEVER commit the real .env to git
# ─────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://saadstudio.app
# Set NEXT_OUTPUT_MODE=standalone only when deploying via Docker (Railway)
# Leave empty for Vercel deployment
NEXT_OUTPUT_MODE=

# ─── Clerk Auth ───────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
# Use pk_live_ / sk_live_ for production
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_replace_me
CLERK_SECRET_KEY=sk_live_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/explore
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/explore
# Get from: Clerk Dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_replace_me

# ─── Supabase (Storage ONLY — images & videos) ───────────────
# Get from: https://supabase.com/dashboard → Settings → API
# Supabase is used ONLY for file storage (images/videos buckets).
# The database (users, credits, subscriptions) is hosted on Neon.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me
# SERVER-SIDE ONLY — Never expose to browser
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me_service_role_key

# ─── Database (Neon PostgreSQL via Prisma) ────────────────────
# Get from: https://console.neon.tech → your project → Connection Details
#
# DATABASE_URL  = Pooled connection (Neon connection pooler, -pooler hostname)
#   Used at runtime (Vercel serverless / Railway). Add ?sslmode=require.
#   Example: postgresql://USER:PASS@ep-xxx-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
#
# DIRECT_URL    = Direct connection (non-pooler hostname)
#   Used ONLY by: prisma migrate deploy / prisma db push
#   Example: postgresql://USER:PASS@ep-xxx-xxx.region.aws.neon.tech/neondb?sslmode=require
#
DATABASE_URL=postgresql://USER:PASS@ep-xxx-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASS@ep-xxx-xxx.region.aws.neon.tech/neondb?sslmode=require

# ─── AI Generation Providers ──────────────────────────────────
OPENAI_API_KEY=sk-replace_me
KIE_API_KEY=replace_me
KIEAI_API_KEY=replace_me
WAVESPEED_API_KEY=replace_me
PIAPI_API_KEY=replace_me
RUNNINGHUB_API_KEY=replace_me

# ─── Stripe ───────────────────────────────────────────────────
STRIPE_API_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ─── Security ─────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=https://saadstudio.app,https://www.saadstudio.app
