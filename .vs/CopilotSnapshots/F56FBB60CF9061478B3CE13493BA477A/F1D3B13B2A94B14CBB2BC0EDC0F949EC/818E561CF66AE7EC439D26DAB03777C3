                                <p className="text-sm text-white/90 leading-relaxed">{prompt}</p>
                                <div className="flex items-center gap-2 mt-2">
                                  <span className="text-[10px] px-2 py-0.5 rounded-full bg-violet-500/20 text-violet-400">{selectedModel.name}</span>
                                  <span className="text-[10px] px-2 py-0.5 rounded-full bg-white/[0.06] text-zinc-400">{selectedRatio}</span>
                                  <span className="text-[10px] px-2 py-0.5 rounded-full bg-white/[0.06] text-zinc-400">{selectedQuality}</span>
                                </div>
                              </div>
                              <button
                                onClick={(e) => { e.stopPropagation(); setShowPromptOverlay(false); }}
                                className="shrink-0 rounded-lg p-1 text-zinc-500 hover:text-white hover:bg-white/10 transition-colors"
                              >
                                <X className="h-4 w-4" />
                              </button>
                            </div>
                          </motion.div>
                        )}
                      </AnimatePresence>
                    </motion.div>

                    {/* ── Floating Action Bar (Glassmorphism) ──────── */}
                    <motion.div
                      initial={{ opacity: 0, y: 20 }}
                      animate={{ opacity: 1, y: 0 }}
                      transition={{ delay: 0.3, duration: 0.4 }}
                      className="mt-6 flex items-center gap-1 rounded-2xl border border-white/[0.08] bg-white/[0.04] backdrop-blur-md px-2 py-2"
                    >
                      {toolbarActions.map((action, idx) => (
                        <React.Fragment key={action.id}>
                          <Tooltip>
                            <TooltipTrigger asChild>
                              <motion.button
                                whileHover={{ scale: 1.15, y: -2 }}
                                whileTap={{ scale: 0.9 }}
                                className={cn(
                                  "flex h-10 w-10 items-center justify-center rounded-xl transition-colors hover:bg-white/[0.08]",
                                  action.color
                                )}
                              >
                                <action.icon className="h-[18px] w-[18px]" />
                              </motion.button>
                            </TooltipTrigger>
                            <TooltipContent
                              side="bottom"
                              className="border-white/[0.08] bg-[#111827] text-white text-xs"
                            >
                              {action.label}
                            </TooltipContent>
                          </Tooltip>
                          {idx < toolbarActions.length - 1 && idx === 3 && (
                            <div className="mx-1 h-5 w-px bg-white/[0.08]" />
                          )}
                        </React.Fragment>
                      ))}
                    </motion.div>
                  </motion.div>
                )}
              </AnimatePresence>
            </div>
          </motion.div>
        </div>
      </div>
    </TooltipProvider>
  );
};

export default ImageGeneratePage;
