// ─── All items flat list (for mobile) ────────────────────────────────────────
const allMobileItems = [
  ...navCategories.directLinks,
  ...navCategories.create.items,
  ...navCategories.studio.items,
  ...navCategories.tools.items,
];

// ─── Sub-link component for dropdown ─────────────────────────────────────────
const ListItem = ({
  href,
  emoji,
  title,
  description,
  icon: Icon,
  color,
}: {
  href: string;
  emoji: string;
  title: string;
  description?: string;
  icon: React.ElementType;
  color: string;
}) => {
  return (
    <li>
      <NavigationMenuLink asChild>
        <Link
          href={href}
          className="block select-none rounded-md p-3 leading-none no-underline outline-none transition-colors hover:bg-white/10 focus:bg-white/10 group"
        >
          <div className="flex items-center gap-3">
            <div className={cn("flex h-9 w-9 items-center justify-center rounded-lg bg-white/5 group-hover:bg-white/10 transition-colors")}>
              <Icon className={cn("h-5 w-5", color)} />
            </div>
            <div>
              <div className="text-sm font-medium leading-none text-white">
                {emoji} {title}
              </div>
              {description && (
                <p className="mt-1 text-xs leading-snug text-zinc-400">
                  {description}
                </p>
              )}
            </div>
          </div>
        </Link>
      </NavigationMenuLink>
    </li>
  );
};

// ─── Credit Balance Button ───────────────────────────────────────────────────
const CreditBalanceButton = ({ apiLimit, isPro }: { apiLimit: number; isPro: boolean }) => {
  const proModal = useProModal();

  return (
    <motion.button
      onClick={() => !isPro && proModal.onOpen()}
      className={cn(
        "relative flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold transition-all",
        "bg-gradient-to-r from-violet-600 to-indigo-600 text-white shadow-lg shadow-violet-500/25",
        "hover:shadow-xl hover:shadow-violet-500/40",
        "overflow-hidden"
      )}
      whileHover={{ scale: 1.05 }}
      whileTap={{ scale: 0.95 }}
    >
      {/* Animated shimmer effect */}
      <motion.div
        className="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent"
        animate={{ x: ["-100%", "100%"] }}
        transition={{ repeat: Infinity, duration: 2, ease: "linear" }}
      />
      <Zap className="relative h-4 w-4 fill-yellow-300 text-yellow-300" />
      <span className="relative">
        {isPro ? "Pro ∞" : `${apiLimit} Credits`}
      </span>
    </motion.button>
  );
};

// ─── Main TopNavbar Component ────────────────────────────────────────────────
export interface TopNavbarProps {
  apiLimit: number;
  isPro: boolean;
}

const TopNavbar = ({ apiLimit = 0, isPro = false }: TopNavbarProps) => {
  const pathname = usePathname();
  const [mobileOpen, setMobileOpen] = useState(false);
  const [mounted, setMounted] = useState(false);
  const [mobileExpanded, setMobileExpanded] = useState<string | null>(null);

  useEffect(() => {
    setMounted(true);
  }, []);

  // Close mobile menu on route change
  useEffect(() => {
    setMobileOpen(false);
  }, [pathname]);

  if (!mounted) return null;

  return (
    <>
      {/* ── Fixed Top Navbar ────────────────────────────────────────────── */}
      <nav className="fixed top-0 left-0 right-0 z-50 border-b border-white/10 bg-[#0a0f1a]/95 backdrop-blur-xl">
        <div className="mx-auto flex h-16 max-w-[1600px] items-center justify-between px-4 lg:px-6">
          {/* ── Left: Logo ──────────────────────────────────────────────── */}
          <Link href="/dash" className="flex items-center gap-3 shrink-0">
            <div className="relative h-8 w-8">
              <Image fill alt="Logo" src="/EveLogo.png" className="object-contain" />
            </div>
            <h1 className={cn("text-xl font-bold text-white tracking-tight", montserrat.className)}>
              Eve
            </h1>
          </Link>

          {/* ── Center: Desktop Navigation ──────────────────────────────── */}
          <div className="hidden lg:flex items-center">
            <NavigationMenu>
              <NavigationMenuList>
                {/* Direct link: Explore */}
                <NavigationMenuItem>
                  <Link href="/dash" legacyBehavior passHref>
                    <NavigationMenuLink className={cn(navigationMenuTriggerStyle(), "text-zinc-300 hover:text-white")}>
                      🌍 Explore
                    </NavigationMenuLink>
                  </Link>
                </NavigationMenuItem>

                {/* Dropdown: Create */}
                <NavigationMenuItem>
                  <NavigationMenuTrigger className="text-zinc-300">
                    🎨 Create
                  </NavigationMenuTrigger>
                  <NavigationMenuContent>
                    <ul className="grid w-[420px] gap-1 p-3 md:grid-cols-2">
                      {navCategories.create.items.map((item) => (
                        <ListItem
                          key={item.href}
                          href={item.href}
                          emoji={item.emoji}
                          title={item.label}
                          description={item.description}
                          icon={item.icon}
                          color={item.color}
                        />
                      ))}
                    </ul>
                  </NavigationMenuContent>
                </NavigationMenuItem>

                {/* Dropdown: Studio */}
                <NavigationMenuItem>
                  <NavigationMenuTrigger className="text-zinc-300">
                    🎬 Studio
                  </NavigationMenuTrigger>
                  <NavigationMenuContent>
                    <ul className="grid w-[480px] gap-1 p-3 md:grid-cols-2">
                      {navCategories.studio.items.map((item) => (
                        <ListItem
                          key={item.href}
                          href={item.href}
                          emoji={item.emoji}
                          title={item.label}
                          description={item.description}
                          icon={item.icon}
                          color={item.color}
                        />
                      ))}
                    </ul>
                  </NavigationMenuContent>
                </NavigationMenuItem>

                {/* Dropdown: Tools */}
                <NavigationMenuItem>
                  <NavigationMenuTrigger className="text-zinc-300">
                    🛠️ Tools
                  </NavigationMenuTrigger>
                  <NavigationMenuContent>
                    <ul className="grid w-[420px] gap-1 p-3 md:grid-cols-1">
                      {navCategories.tools.items.map((item) => (
                        <ListItem
                          key={item.href}
                          href={item.href}
                          emoji={item.emoji}
                          title={item.label}
                          description={item.description}
                          icon={item.icon}
                          color={item.color}
                        />
                      ))}
                    </ul>
                  </NavigationMenuContent>
                </NavigationMenuItem>

                {/* Direct link: Gallery */}
                <NavigationMenuItem>
                  <Link href="/gallery" legacyBehavior passHref>
                    <NavigationMenuLink className={cn(navigationMenuTriggerStyle(), "text-zinc-300 hover:text-white")}>
                      🖼️ Gallery
                    </NavigationMenuLink>
                  </Link>
                </NavigationMenuItem>
              </NavigationMenuList>
            </NavigationMenu>
          </div>

          {/* ── Right: Credits + Profile + Hamburger ───────────────────── */}
          <div className="flex items-center gap-3">
            <CreditBalanceButton apiLimit={apiLimit} isPro={isPro} />

            <div className="hidden lg:block">
              <UserButton />
            </div>

            {/* Mobile hamburger */}
            <button
              className="lg:hidden flex items-center justify-center h-10 w-10 rounded-lg text-zinc-400 hover:text-white hover:bg-white/10 transition-colors"
              onClick={() => setMobileOpen(!mobileOpen)}
              aria-label="Toggle mobile menu"
            >
              {mobileOpen ? <X className="h-5 w-5" /> : <Menu className="h-5 w-5" />}
            </button>
          </div>
        </div>
      </nav>

      {/* ── Mobile Menu Overlay ──────────────────────────────────────────── */}
      <AnimatePresence>
        {mobileOpen && (
