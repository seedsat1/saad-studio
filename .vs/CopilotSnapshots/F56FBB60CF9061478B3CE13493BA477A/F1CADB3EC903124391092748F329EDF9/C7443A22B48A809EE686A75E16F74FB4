    items: [
      { emoji: "🎭", label: "Character", href: "/character", icon: Drama, color: "text-violet-500", description: "Design AI characters & avatars" },
      { emoji: "🎨", label: "Moodboard", href: "/moodboard", icon: Palette, color: "text-rose-500", description: "Curate visual inspiration boards" },
      { emoji: "🎬", label: "Cinema Studio", href: "/cinema-studio", icon: Clapperboard, color: "text-amber-500", description: "Professional cinematic production" },
      { emoji: "📺", label: "Original Series", href: "/original-series", icon: Monitor, color: "text-blue-500", description: "Create episodic AI content" },
    ],
  },
